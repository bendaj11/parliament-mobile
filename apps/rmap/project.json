{
  "name": "rmap",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/rmap/src",
  "projectType": "application",
  "tags": ["atlas"],
  "// targets": "to see all targets run: nx show project rmap --web",
  "targets": {
    "atlas:config": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.atlas"],
      "options": {
        "command": "atlas compile-config rmap"
      }
    },
    "atlas:publish": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["build"],
      "options": {
        "command": "atlas publish rmap --from-build-output",
        "forwardAllArgs": true
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "atlas dev rmap",
        "forwardAllArgs": true
      }
    },
    "rmap": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx run rmap:dev",
        "forwardAllArgs": true
      }
    }
  }
}
