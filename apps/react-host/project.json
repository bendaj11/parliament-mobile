{
  "name": "react-host",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/react-host/src",
  "projectType": "application",
  "tags": ["atlas"],
  "// targets": "to see all targets run: nx show project react-host --web",
  "targets": {
    "atlas:config": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.atlas"],
      "options": {
        "command": "atlas compile-config react-host"
      }
    },
    "atlas:publish": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["build"],
      "options": {
        "command": "atlas publish react-host --from-build-output",
        "forwardAllArgs": true
      }
    },
    "atlas:bootstrap": {
      "executor": "nx:run-commands",
      "dependsOn": ["atlas:config"],
      "outputs": ["{projectRoot}/dist/bootstrap"],
      "options": {
        "command": "atlas build-bootstrap react-host --skip-compile",
        "forwardAllArgs": true
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "atlas dev react-host",
        "forwardAllArgs": true
      }
    },
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/react-host",
        "command": "vite"
      }
    },
    "react-host": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx run react-host:dev",
        "forwardAllArgs": true
      }
    }
  }
}
